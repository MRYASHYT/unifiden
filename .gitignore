# Unifiden Secure .gitignore

# Secrets
.env
.env.example
secrets.json

# Security Keys (CRITICAL)
security/keys/
*.pem
*.key

# Ignore data files but KEEP the python modules
data/*.jsonl
results/*.csv
results/*.png
results/*.json
paper/figures/

# Python Artifacts
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/

# IDE
.vscode/
.idea/

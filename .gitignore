# AgentStress Secure .gitignore

# Secrets
.env
.env.*
!.env.example
secrets.json

# Security Keys (CRITICAL)
security/keys/
*.pem
*.key

# Ignore data files but KEEP the python modules
data/*.jsonl
agentstress/data/*.jsonl
results/*.csv
results/*.png
results/*.json
paper/figures/

# Python Artifacts
__pycache__/
*.py[cod]
*$py.class
agentstress.log
tests/test_keys/
tests/temp_keys/
tests/temp_ledger.jsonl
*.egg-info/
venv/
.venv/

# IDE
.vscode/
.idea/
